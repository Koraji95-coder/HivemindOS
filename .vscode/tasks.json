{
  "version": "2.0.0",  // VS Code task format version, DO NOT TOUCH
  "_hivemind_version": "v0.2.2",
  "tasks": [
    {
      "label": "Run Backend (FastAPI)",
      "type": "shell",
      "command": "python",
      "args": [
        "-m", "uvicorn", "backend.fastapi_main:app", "--reload"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "Launches FastAPI backend server"
    },
    {
      "label": "Run UI (Vue Dev Server)",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c", "npm run dev"
      ],
      "options": {
        "cwd": "hivemind-ui"
      },
      "group": "build",
      "problemMatcher": [],
      "detail": "Launches Vite UI from hivemind-ui/"
    }
  ]
}